<?xml version="1.0" encoding="UTF-8"?>
<!--
  Four-Bar Linkage URDF
  Crank-Rocker-Rocker Configuration
  
  Dimensions:
    Ground (L1): 80mm = 0.08m
    Crank  (L2): 50mm = 0.05m
    Coupler(L3): 100mm = 0.10m
    Rocker (L4): 80mm = 0.08m
  
  Colors mapping requested by user:
    Ground  = Yellow
    Crank   = Pink
    Coupler = Black
    Rocker  = Blue
-->
<robot name="four_bar_linkage">

  <!-- ==================== MATERIALS ==================== -->
  <material name="yellow">
    <color rgba="0.9 0.85 0.1 1.0"/>
  </material>
  <material name="pink">
    <color rgba="0.9 0.3 0.6 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.9 1.0"/>
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>

  <!-- ==================== GROUND LINK (L1 = 80mm) - YELLOW ==================== -->
  <link name="ground_link">
    <visual>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.02 0.008"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <inertial>
      <origin xyz="0.04 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="fixed_base" type="fixed">
    <parent link="base_link"/>
    <child link="ground_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CRANK LINK (L2 = 50mm) - PINK ==================== -->
  <link name="crank_link">
    <visual>
      <origin xyz="0.025 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.02 0.008"/>
      </geometry>
      <material name="pink"/>
    </visual>
    <inertial>
      <origin xyz="0.025 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="joint_A" type="revolute">
    <parent link="ground_link"/>
    <child link="crank_link"/>
    <origin xyz="0 0 0.009" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="3.14"/>
  </joint>

  <!-- ==================== COUPLER LINK (L3 = 100mm) - BLACK ==================== -->
  <link name="coupler_link">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.02 0.008"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <origin xyz="0.05 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="joint_B" type="revolute">
    <parent link="crank_link"/>
    <child link="coupler_link"/>
    <origin xyz="0.05 0 0.009" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="3.14"/>
  </joint>

  <!-- ==================== ROCKER LINK (L4 = 80mm) - BLUE ==================== -->
  <link name="rocker_link">
    <visual>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.02 0.008"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <origin xyz="0.04 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="joint_C" type="revolute">
    <parent link="coupler_link"/>
    <child link="rocker_link"/>
    <origin xyz="0.10 0 0.009" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="3.14"/>
  </joint>

</robot>
